# ============================================================
# FiscalIA — Variables de Entorno
# ============================================================

# IA (GRATIS) — https://console.groq.com
GROQ_API_KEY=gsk_tu-clave-groq-aqui

# Seguridad JWT
SECRET_KEY=cambia-esta-clave-secreta
ADMIN_SECRET_KEY=clave-admin-secreta

# ── BASE DE DATOS ─────────────────────────────────────────────
# Opción A: Supabase (recomendado para producción en Render)
# Obtén la URL en: supabase.com → proyecto → Settings → Database → Connection string → URI
# IMPORTANTE: usa el formato "Transaction pooler" (puerto 6543)
DATABASE_URL=postgresql://postgres.XXXX:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# Opción B: SQLite local (solo para desarrollo en tu ordenador)
# DATABASE_URL=sqlite+aiosqlite:///./fiscalia.db

# Trial gratuito para nuevos usuarios (días)
FREE_TRIAL_DAYS=7

# ── STRIPE (opcional) ─────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...
